[Unit]
Description=trade-terminal-cockpit command gateway boundary
Documentation=file:%h/projects/trading/repos/services/trade-terminal-cockpit/README.md
After=network-online.target
Wants=network-online.target
PartOf=trading-ui.target
ConditionPathExists=%h/projects/trading/repos/services/trade-terminal-cockpit/.run/bin/command-gateway

[Service]
Type=simple
WorkingDirectory=%h/projects/trading/repos/services/trade-terminal-cockpit
EnvironmentFile=-%E/trade-terminal-cockpit/external.env
ExecStartPre=/bin/bash -lc 'tools/check_external_integration.py --env-file "${XDG_CONFIG_HOME:-$HOME/.config}/trade-terminal-cockpit/external.env"'
ExecStart=%h/projects/trading/repos/services/trade-terminal-cockpit/tools/run_command_gateway_service.sh
Restart=on-failure
RestartSec=1
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/projects/trading/repos/services/trade-terminal-cockpit/.run %E/trade-terminal-cockpit %t
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
RestrictNamespaces=yes
RestrictRealtime=yes
LockPersonality=yes
RestrictSUIDSGID=yes
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM

[Install]
WantedBy=trading-ui.target
