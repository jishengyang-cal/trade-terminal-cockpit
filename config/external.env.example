# trade-terminal-cockpit external integration profile.
#
# Copy to $XDG_CONFIG_HOME/trade-terminal-cockpit/external.env or pass with
# tools/open_external_tui.sh --env-file PATH. Keep secrets out of this file.

# NATS / JetStream trading-domain event stream. This must be a trading-domain
# stream, not the phase-1 OPS control-bus stream.
TRADE_COCKPIT_NATS_URL=nats://127.0.0.1:14222
TRADE_COCKPIT_NATS_MONITOR_URL=http://127.0.0.1:18222
TRADE_COCKPIT_JETSTREAM_STREAM=TRADING_EVENTS
TRADE_COCKPIT_NATS_SUBJECT='trading.event.>'
TRADE_COCKPIT_AUDIT_STREAM=TRADING_AUDIT
TRADE_COCKPIT_AUDIT_SUBJECTS='trading.audit.>,trading.command.>'
TRADE_COCKPIT_EVENT_CODEC=protobuf
TRADE_COCKPIT_JETSTREAM_DURABLE=trade-terminal-cockpit-local

# Local projection and command boundary services.
TRADE_COCKPIT_PROJECTION_ADDR=127.0.0.1:39731
TRADE_COCKPIT_COMMAND_GATEWAY_ADDR=127.0.0.1:39732
TRADE_COCKPIT_COMMAND_AUDIT_JSONL=.run/command-gateway-audit.jsonl
TRADE_COCKPIT_POLICY_JSON=examples/command-gateway-policy.example.json
TRADE_COCKPIT_ADAPTER_TIMEOUT_MS=750

# Runtime identity. The TUI includes these in every command envelope.
TRADE_COCKPIT_OPERATOR_ID=operator-local
TRADE_COCKPIT_SESSION_ID=trade-terminal-cockpit-local
TRADE_COCKPIT_TARGET_ENVIRONMENT=paper

# External adapters. These are optional unless command execution through the
# corresponding adapter is enabled. The TUI never calls them directly.
TRADE_COCKPIT_RISK_CHECK_BIN=$HOME/projects/trading/repos/services/trade-terminal-cockpit/tools/risk_command_adapter.py
TRADE_COCKPIT_RISK_ENGINE_BIN=$HOME/projects/trading/repos/trading-risk-engine/target/debug/risk-engine-service
TRADE_COCKPIT_RISK_AUTHORITY_TOML=$HOME/projects/trading/repos/trading-risk-engine/authority/trading_risk_engine_authority.toml
TRADE_COCKPIT_RISK_LIVENESS_CACHE_TTL_MS=30000
TRADE_COCKPIT_RISK_LIVE_ON_CACHE_MISS=0
TRADE_COCKPIT_STRATEGY_CONTROL_BIN=
TRADE_COCKPIT_ORDER_GATEWAY_BIN=
TRADE_COCKPIT_ALERT_SERVICE_BIN=

# Broker-control adapter for account/global runtime control. Disabled by
# default; set TRADE_COCKPIT_ENABLE_BROKER_CONTROL=1 only when the broker runtime
# is intentionally active and operator policy is ready.
TRADE_COCKPIT_ENABLE_BROKER_CONTROL=0
TRADE_COCKPIT_BROKER_RUNTIME_DIR=$HOME/.local/state/broker-core/runtime
TRADE_COCKPIT_BROKER_CONTROL_BIN=$HOME/.local/bin/broker-control-gateway
TRADE_COCKPIT_BROKER_ACCOUNT_SLOTS=
